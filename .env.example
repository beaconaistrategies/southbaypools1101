# SquareKeeper Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL connection string
# For Supabase: Go to Project Settings > Database > Connection string (URI)
# For Neon: Copy from your Neon dashboard
DATABASE_URL=postgresql://user:password@host:port/database

# ===========================================
# AUTHENTICATION (Required)
# ===========================================
# Session encryption secret (generate a random 32+ character string)
# Run: openssl rand -hex 32
SESSION_SECRET=your-super-secret-session-key-here

# ===========================================
# DATAGOLF API (Required for Golf Earnings Pools)
# ===========================================
# Get your API key from https://datagolf.com
DATAGOLF_API_KEY=your-datagolf-api-key-here

# ===========================================
# VERCEL CRON (Required for live scoring on Vercel)
# ===========================================
# Secret used to authenticate cron job requests
# Run: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ===========================================
# OPTIONAL FEATURES
# ===========================================

# n8n Webhook URL for email notifications
# Leave empty to disable webhook notifications
# WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxxxx

# ===========================================
# DEVELOPMENT
# ===========================================
# Set to "development" for local development
NODE_ENV=development

# Server port (default: 5000)
PORT=5000
