# SquareKeeper Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/squarekeeper

# Individual database connection parameters (used by some tools)
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password
PGDATABASE=squarekeeper

# ===========================================
# AUTHENTICATION (Required)
# ===========================================
# Session encryption secret (generate a random 32+ character string)
# Example: openssl rand -hex 32
SESSION_SECRET=your-super-secret-session-key-here

# ===========================================
# REPLIT AUTH (Auto-configured on Replit)
# ===========================================
# These are automatically set when running on Replit
# If running locally, you'll need to set up OIDC credentials
# REPLIT_DOMAINS=your-repl-name.your-username.repl.co
# REPLIT_DEV_DOMAIN=your-repl-name.your-username.repl.co
# REPL_ID=your-repl-id

# ===========================================
# OPTIONAL FEATURES
# ===========================================

# n8n Webhook URL for email notifications
# Leave empty to disable webhook notifications
# WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxxxx

# ===========================================
# DEVELOPMENT
# ===========================================
# Set to "development" for local development
NODE_ENV=development

# Server port (default: 5000)
PORT=5000
